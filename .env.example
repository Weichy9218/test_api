# Example: copy to .env and fill in your keys
# cp .env.example .env

# ─── Sub2API（主要教程使用的 API）─────────────────────────────────────────────
# 填入你获得的 API key 和 base URL
SUB2API_API_KEY=sk-your-key-here
SUB2API_BASE_URL=https://ie-crs.haoxiang.ai/v1

# ─── OpenRouter（可选）────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── 其他 OpenAI 兼容中转（可选）─────────────────────────────────────────────
NEW_API_KEY=sk-your-key-here
NEW_BASE_URL=https://your-proxy.example.com
